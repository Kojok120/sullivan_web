generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Subject {
  id           String        @id @default(cuid())
  name         String        @unique
  icon         String?
  order        Int
  coreProblems CoreProblem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model CoreProblem {
  id              String                 @id @default(cuid())
  name            String
  subjectId       String
  subject         Subject                @relation(fields: [subjectId], references: [id])
  problems        Problem[]
  userStates      UserCoreProblemState[]
  order           Int
  lectureVideos   Json?                  // 講義動画 [{ title: string, url: string }]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model Problem {
  id              String             @id @default(cuid())
  question        String
  answer          String?
  customId        String?            @unique // Custom ID (e.g., E-1, S-10)
  acceptedAnswers String[]           @default([]) // 許容解答（複数）
  grade           String?            // 学年 (e.g., "中1", "高2")
  masterNumber    Int?               @unique // マスタ内問題番号
  coreProblems    CoreProblem[]
  order           Int // Chain order
  videoUrl        String? // For C/D feedback
  histories       LearningHistory[]
  userStates      UserProblemState[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum Role {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique // Auto-generated ID (e.g., S0001)
  password  String   // Hashed password
  role      Role     @default(STUDENT)
  name      String?
  group     String?  // 所属グループ名 (e.g., "月曜")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?

  learningHistory       LearningHistory[]
  userProblemStates     UserProblemState[]

  userCoreProblemStates UserCoreProblemState[]

  // Gamification
  xp             Int      @default(0)
  level          Int      @default(1)
  currentStreak  Int      @default(0)
  maxStreak      Int      @default(0)
  lastStudyDate  DateTime?

  achievements   UserAchievement[]
  dailySummaries DailyLearningSummary[]
  realtimeEvents RealtimeEvent[]


  // Teacher specific fields
  bio             String? // 生徒プロフィール（部活、志望校など）
  notes           String? // 講師用メモ（性格、特記事項など）
  birthday        DateTime? // 生年月日
  classroomId     String?
  classroom       Classroom?       @relation(fields: [classroomId], references: [id])
  school          String? // 学校
  phoneNumber     String? // 電話番号
  email           String? // メールアドレス
  guidanceRecords GuidanceRecord[] @relation("StudentGuidance")
  createdGuidance GuidanceRecord[] @relation("TeacherGuidance")
}

model Classroom {
  id        String   @id @default(cuid())
  name      String   @unique
  groups    String[] @default([]) // 教室内のグループ（曜日など）
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GuidanceType {
  INTERVIEW // 面談
  GUIDANCE // 指導
  OTHER // その他
}

model GuidanceRecord {
  id        String       @id @default(cuid())
  studentId String
  student   User         @relation("StudentGuidance", fields: [studentId], references: [id])
  teacherId String
  teacher   User         @relation("TeacherGuidance", fields: [teacherId], references: [id])
  date      DateTime     @default(now())
  content   String
  type      GuidanceType @default(GUIDANCE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model LearningHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  evaluation String // A, B, C, D
  userAnswer String? // User's text answer
  feedback   String? // AI feedback
  answeredAt DateTime @default(now())
  
  // Grouping & Video Logic
  groupId        String?   // UUID for batch grouping
  isVideoWatched Boolean   @default(false)
  isStudentReviewed Boolean @default(false) // New: Has the student reviewed this history?
}

model UserProblemState {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  problemId      String
  problem        Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  priority       Int       @default(0)
  lastAnsweredAt DateTime?
  isCleared      Boolean   @default(false)

  @@unique([userId, problemId])
}

model UserCoreProblemState {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  coreProblemId String
  coreProblem   CoreProblem @relation(fields: [coreProblemId], references: [id])
  priority      Int         @default(0) // ポイント
  isUnlocked    Boolean     @default(false)

  @@unique([userId, coreProblemId])
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., "streak-7"
  name        String
  description String
  icon        String
  xpReward    Int      @default(0)
  isHidden    Boolean  @default(false)

  users       UserAchievement[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())
  isSeen        Boolean     @default(false)

  @@unique([userId, achievementId])
}

model DailyLearningSummary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime // YYYY-MM-DD 00:00:00
  count       Int      @default(0)

  @@unique([userId, date])
}

model RealtimeEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("realtime_events")
}

enum GradingJobStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model GradingJob {
  id        String           @id @default(cuid())
  fileId    String           @unique @map("file_id")
  fileName  String           @map("file_name")
  status    GradingJobStatus
  attempts  Int              @default(1)
  lastError String?          @map("last_error")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("grading_jobs")
}
