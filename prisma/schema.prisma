generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subject {
  id           String        @id @default(cuid())
  name         String        @unique
  icon         String?
  order        Int
  coreProblems CoreProblem[]
  problems     Problem[]
  studentGoals StudentGoal[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model CoreProblem {
  id            String                 @id @default(cuid())
  name          String
  masterNumber  Int
  subjectId     String
  subject       Subject                @relation(fields: [subjectId], references: [id])
  problems      Problem[]
  userStates    UserCoreProblemState[]
  order         Int
  lectureVideos Json? // 講義動画 [{ title: string, url: string }]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([subjectId, masterNumber])
}

model Problem {
  id                   String               @id @default(cuid())
  question             String
  answer               String?
  customId             String // Custom ID (e.g., E-1, S-10)
  /// 自然順ソートキー（PostgreSQL 側で STORED 生成カラム / public.problem_custom_id_sort_key("customId")）
  customIdSortKey      String?              @db.Text

  acceptedAnswers      String[]             @default([]) // 許容解答（複数）
  grade                String? // 学年 (e.g., "中1", "高2")
  masterNumber         Int? // マスタ内問題番号
  problemType          ProblemType          @default(SHORT_TEXT)
  contentFormat        ProblemContentFormat @default(PLAIN_TEXT)
  status               ProblemStatus        @default(PUBLISHED)
  hasStructuredContent Boolean              @default(false)
  publishedRevisionId  String?              @unique
  subjectId            String
  subject              Subject              @relation(fields: [subjectId], references: [id])
  coreProblems         CoreProblem[]
  publishedRevision    ProblemRevision?     @relation("PublishedProblemRevision", fields: [publishedRevisionId], references: [id], onDelete: SetNull)
  revisions            ProblemRevision[]    @relation("ProblemRevisions")
  order                Int // Chain order
  videoUrl             String? // For C/D feedback
  videoStatus          VideoStatus          @default(NONE) // 動画制作ステータス
  sentBackReason       String? // 差し戻し理由（最後に SENT_BACK にした際のテキスト）
  histories            LearningHistory[]
  userStates           UserProblemState[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([subjectId, customId])
  @@unique([subjectId, masterNumber])
  @@index([subjectId, status])
}

enum ProblemType {
  SHORT_TEXT
  GEOMETRY
  GRAPH_DRAW
}

enum ProblemContentFormat {
  PLAIN_TEXT
  STRUCTURED_V1
}

enum ProblemStatus {
  DRAFT
  PUBLISHED
  SENT_BACK
  ARCHIVED
}

enum ProblemRevisionStatus {
  DRAFT
  PUBLISHED
  SUPERSEDED
  ARCHIVED
}

enum ProblemAuthoringTool {
  MANUAL
  DESMOS
  GEOGEBRA
  SVG
  UPLOAD
}

enum VideoStatus {
  NONE // 未対応
  SHOT // 撮影完了
  UPLOADED // Drive 完了
  CONFIGURED // 設定済み（videoUrl 設定済み）
}

enum PrintTemplate {
  COMPACT
  STANDARD
  WORKSPACE
  GRAPH
  TABLE
  EXPLANATION
}

enum ProblemAssetKind {
  IMAGE
  SVG
  PDF
  DESMOS_STATE
  GEOGEBRA_STATE
  JSON
  THUMBNAIL
}

model ProblemRevision {
  id                  String                @id @default(cuid())
  problemId           String
  revisionNumber      Int
  status              ProblemRevisionStatus @default(DRAFT)
  structuredContent   Json?
  answerSpec          Json?
  printConfig         Json?
  generationContext   Json?
  authoringTool       ProblemAuthoringTool  @default(MANUAL)
  authoringState      Json?
  createdByUserId     String?
  publishedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  problem             Problem               @relation("ProblemRevisions", fields: [problemId], references: [id], onDelete: Cascade)
  publishedForProblem Problem?              @relation("PublishedProblemRevision")
  assets              ProblemAsset[]
  histories           LearningHistory[]

  @@unique([problemId, revisionNumber])
  @@index([problemId, status, revisionNumber])
}

model ProblemAsset {
  id                String               @id @default(cuid())
  problemRevisionId String
  kind              ProblemAssetKind
  fileName          String
  storageKey        String?
  mimeType          String
  width             Int?
  height            Int?
  checksum          String?
  sourceTool        ProblemAuthoringTool @default(UPLOAD)
  metadata          Json?
  inlineContent     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  problemRevision   ProblemRevision      @relation(fields: [problemRevisionId], references: [id], onDelete: Cascade)

  @@index([problemRevisionId, kind])
}

enum Role {
  STUDENT
  TEACHER
  HEAD_TEACHER
  PARENT
  ADMIN
  MATERIAL_AUTHOR
}

enum ClassroomPlan {
  STANDARD
  PREMIUM
}

enum StudentGoalType {
  PROBLEM_COUNT
  CUSTOM
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique // Auto-generated ID (e.g., S0001)
  role      Role     @default(STUDENT)
  name      String?
  group     String? // 所属グループ名 (e.g., "月曜")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?

  learningHistory   LearningHistory[]
  userProblemStates UserProblemState[]

  userCoreProblemStates UserCoreProblemState[]

  // Gamification
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  maxStreak     Int       @default(0)
  lastStudyDate DateTime?

  achievements    UserAchievement[]
  dailySummaries  DailyLearningSummary[]
  realtimeEvents  RealtimeEvent[]
  surveyResponses SurveyResponse[]

  // Teacher specific fields
  bio                  String? // 生徒プロフィール（部活、志望校など）
  notes                String? // 講師用メモ（性格、特記事項など）
  birthday             DateTime? // 生年月日
  classroomId          String?
  classroom            Classroom?            @relation(fields: [classroomId], references: [id])
  school               String? // 学校
  phoneNumber          String? // 電話番号
  email                String? // メールアドレス
  guidanceRecords      GuidanceRecord[]      @relation("StudentGuidance")
  createdGuidance      GuidanceRecord[]      @relation("TeacherGuidance")
  studentGoals         StudentGoal[]         @relation("StudentGoals")
  createdGoals         StudentGoal[]         @relation("CreatedStudentGoals")
  updatedGoals         StudentGoal[]         @relation("UpdatedStudentGoals")
  vocabularyGameScores VocabularyGameScore[]
  statsDaily           UserStatsDaily[]

  @@index([classroomId, role])
}

/// 日次の学習集計。LearningHistory の (userId, date(answeredAt)) GROUP BY を
/// 事前計算してキャッシュする。dashboard / heatmap の 365 日 GROUP BY を
/// 単純な範囲読み出しに置き換えるための非正規化テーブル。
/// 当日分は live で計算し、履歴日分はこのテーブルから読む運用。
/// 集計はバックフィルスクリプトと worker /internal/recompute-stats-daily で再計算する。
model UserStatsDaily {
  userId       String
  date         DateTime @db.Date // 日付 (UTC)
  totalSolved  Int      @default(0)
  correctCount Int      @default(0) // evaluation A/B
  xpEarned     Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([userId, date(sort: Desc)])
}

model StudentGoal {
  id                 String                 @id @default(cuid())
  studentId          String
  student            User                   @relation("StudentGoals", fields: [studentId], references: [id], onDelete: Cascade)
  type               StudentGoalType
  name               String
  subjectId          String?
  subject            Subject?               @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  dueDateKey         String // YYYY-MM-DD
  createdByTeacherId String
  createdByTeacher   User                   @relation("CreatedStudentGoals", fields: [createdByTeacherId], references: [id], onDelete: Restrict)
  updatedByTeacherId String
  updatedByTeacher   User                   @relation("UpdatedStudentGoals", fields: [updatedByTeacherId], references: [id], onDelete: Restrict)
  deletedAt          DateTime?
  milestones         StudentGoalMilestone[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([studentId, dueDateKey, deletedAt])
}

model StudentGoalMilestone {
  id          String      @id @default(cuid())
  goalId      String
  goal        StudentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dateKey     String // YYYY-MM-DD
  targetCount Int?
  targetText  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([goalId, dateKey])
  @@index([goalId, dateKey])
}

model Classroom {
  id        String        @id @default(cuid())
  name      String        @unique
  plan      ClassroomPlan @default(STANDARD)
  groups    String[]      @default([]) // 教室内のグループ（曜日など）
  users     User[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum GuidanceType {
  INTERVIEW // 面談
  GUIDANCE // 指導
  OTHER // その他
}

enum GuidanceRecordStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model GuidanceRecord {
  id                  String               @id @default(cuid())
  studentId           String
  student             User                 @relation("StudentGuidance", fields: [studentId], references: [id])
  teacherId           String
  teacher             User                 @relation("TeacherGuidance", fields: [teacherId], references: [id])
  date                DateTime             @default(now())
  content             String
  type                GuidanceType         @default(GUIDANCE)
  status              GuidanceRecordStatus @default(COMPLETED)
  summaryErrorCode    String?
  summaryErrorMessage String?
  summaryJobAttempts  Int                  @default(0)
  geminiFileName      String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status, updatedAt])
}

model LearningHistory {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  problemId         String
  problem           Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemRevisionId String?
  problemRevision   ProblemRevision? @relation(fields: [problemRevisionId], references: [id], onDelete: SetNull)
  evaluation        String // A, B, C, D
  userAnswer        String? // User's text answer
  feedback          String? // AI feedback
  answeredAt        DateTime         @default(now())

  // Grouping & Video Logic
  groupId           String? // UUID for batch grouping
  isVideoWatched    Boolean @default(false)
  isStudentReviewed Boolean @default(false) // 生徒がこの履歴を確認済みか

  @@index([userId, answeredAt(sort: Desc)])
  @@index([groupId, userId, id])
  @@index([userId, groupId, isStudentReviewed])
  @@index([userId, groupId, answeredAt(sort: Desc)])
}

model VocabularyGameScore {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId    String
  score        Int
  correctCount Int
  totalCount   Int
  maxCombo     Int
  level        String
  playedAt     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, sessionId])
  @@index([playedAt])
  @@index([userId, playedAt])
}

model UserProblemState {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  problemId            String
  problem              Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  priority             Int       @default(0)
  lastAnsweredAt       DateTime?
  isCleared            Boolean   @default(false)
  unlockLastAnsweredAt DateTime?
  unlockIsCleared      Boolean   @default(false)

  @@unique([userId, problemId])
}

model UserCoreProblemState {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  coreProblemId    String
  coreProblem      CoreProblem @relation(fields: [coreProblemId], references: [id])
  priority         Int         @default(0) // ポイント
  isUnlocked       Boolean     @default(false)
  isLectureWatched Boolean     @default(true) // 講義動画視聴済みフラグ（既存データはtrue）
  lectureWatchedAt DateTime? // 視聴完了日時

  @@unique([userId, coreProblemId])
  @@index([userId, isUnlocked, isLectureWatched])
}

model Achievement {
  id          String  @id @default(cuid())
  slug        String  @unique // e.g., "streak-7"
  name        String
  description String
  icon        String
  xpReward    Int     @default(0)
  isHidden    Boolean @default(false)

  users     UserAchievement[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())
  isSeen        Boolean     @default(false)

  @@unique([userId, achievementId])
}

model DailyLearningSummary {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  date   DateTime // YYYY-MM-DD 00:00:00
  count  Int      @default(0)

  @@unique([userId, date])
}

model RealtimeEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("realtime_events")
}

enum GradingJobStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model GradingJob {
  id        String           @id @default(cuid())
  fileId    String           @unique @map("file_id")
  fileName  String           @map("file_name")
  status    GradingJobStatus
  attempts  Int              @default(1)
  lastError String?          @map("last_error")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("grading_jobs")
}

model DistributedLock {
  key       String   @id
  ownerId   String   @map("owner_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("distributed_locks")
}

model DriveWatchState {
  scopeKey   String   @id @map("scope_key")
  channelId  String   @map("channel_id")
  resourceId String   @map("resource_id")
  token      String?
  expiration DateTime
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("drive_watch_states")
}

enum SurveyCategory {
  GRIT
  SELF_EFFICACY
  SELF_REGULATION
  GROWTH_MINDSET
  EMOTIONAL_REGULATION
}

model QuestionBank {
  id        String         @id @default(cuid())
  category  SurveyCategory
  question  String
  createdAt DateTime       @default(now())
}

model SurveyResponse {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  answeredAt DateTime @default(now())
  details    Json // 詳細な回答データ
  scores     Json // カテゴリごとのスコア

  @@index([userId, answeredAt(sort: Desc)])
}
